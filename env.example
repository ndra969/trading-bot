# Database Configuration
# Options:
# - sqlite+aiosqlite:///trading_bot.db
# - postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///trading_bot.db

# Trading Configuration
# Environment: development, production
TRADING_ENV=development
# Log Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Dry Run Mode: true (safe), false (real trading)
DRY_RUN=true

# MetaTrader 5 Credentials (Optional if terminal is already logged in)
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=Broker-Server

# Notifications (Telegram)
# Get Token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Get Chat ID from @userinfobot or channel ID
TELEGRAM_CHAT_ID=123456789
