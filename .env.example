# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# TELEGRAM NOTIFICATIONS
# =============================================================================
# Required for real-time trading notifications
# Get bot token from @BotFather on Telegram
# Get chat ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# METATRADER5 CONFIGURATION (Optional)
# =============================================================================
# Only required if using specific MT5 login credentials
# Usually not needed - bot connects to running MT5 terminal
# MT5_LOGIN=your_mt5_login
# MT5_PASSWORD=your_mt5_password
# MT5_SERVER=your_mt5_server

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# SQLite (default - development)
# DATABASE_URL=sqlite+aiosqlite:///trading_bot.db

# PostgreSQL (production - uncomment to use)
DATABASE_URL=postgresql+asyncpg://trading_bot_user:trading_bot_password@localhost:5432/trading_bot_db

# PostgreSQL Connection Details (for setup scripts)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_bot_db
POSTGRES_USER=trading_bot_user
POSTGRES_PASSWORD=trading_bot_password

# PostgreSQL Admin Details (for database setup)
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=admin

# =============================================================================
# LOGGING CONFIGURATION (Optional)
# =============================================================================
# Override default logging level
# LOG_LEVEL=INFO

# =============================================================================
# TRADING MODE (Optional)
# =============================================================================
# Override default trading mode
# TRADING_MODE=development

# =============================================================================
# API CONFIGURATION (Optional)
# =============================================================================
# Override default API keys for external services
# ALPHA_VANTAGE_API_KEY=your_api_key_here
# FINNHUB_API_KEY=your_api_key_here

# =============================================================================
# MONITORING & ANALYTICS (Optional)
# =============================================================================
# Override default monitoring settings
# MONITORING_UPDATE_INTERVAL=2.0
# ANALYTICS_OUTPUT_DIR=reports

# =============================================================================
# SECURITY WARNING
# =============================================================================
# 1. Never commit your actual .env file to version control
# 2. Never share your bot token or chat ID publicly
# 3. Keep your MT5 credentials secure
# 4. Use environment variables for sensitive data