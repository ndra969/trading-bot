erDiagram
    %% =============================================================================
    %% ADVANCED TRADING BOT DATABASE SCHEMA
    %% Complete ERD with Position Management, Strategy Analysis & Risk Management
    %% =============================================================================

    %% Core Trading Entities
    TRADING_SESSIONS {
        string session_id PK "Unique session identifier"
        string trading_type "SCALPING, DAY_TRADING, SWING_TRADING, POSITION_TRADING"
        string config_profile "Configuration profile name"
        boolean dry_run "Paper trading mode flag"
        datetime start_time "Session start timestamp"
        datetime end_time "Session end timestamp"
        string status "ACTIVE, COMPLETED, TERMINATED"
        json session_metadata "Additional session information"
        datetime created_at "Record creation time"
        datetime updated_at "Record last update time"
    }

    %% Position Management Entities (Enhanced with Pip Tracking)
    POSITIONS {
        string position_id PK "Unique position identifier"
        string session_id FK "Related trading session"
        string symbol "Trading symbol (EURUSD, XAUUSD, etc.)"
        string asset_class "FOREX_MAJOR, FOREX_JPY, COMMODITIES, CRYPTO"
        string direction "LONG or SHORT"
        float entry_price "Position entry price"
        datetime entry_time "Position entry timestamp"
        float volume "Position volume/lot size"
        float current_stop_loss "Current stop loss level"
        float current_take_profit "Current take profit level"
        float current_price "Current market price"
        string status "OPEN, BREAKEVEN, TRAILING, PARTIAL_CLOSED, CLOSED"
        boolean breakeven_activated "Breakeven automation status"
        boolean trailing_activated "Trailing stop automation status"
        float pip_size "Asset-specific pip size (0.0001, 0.01, 0.1, 1.0)"
        float pip_value_per_lot "USD value per pip for 1 lot"
        float entry_to_sl_pips "Distance to stop loss in pips"
        float entry_to_tp_pips "Distance to take profit in pips"
        float current_profit_pips "Current profit/loss in pips"
        float risk_amount_usd "USD amount at risk (if SL hit)"
        float potential_profit_usd "USD potential profit (if TP hit)"
        float current_pnl_usd "Current unrealized P&L in USD"
        datetime created_at "Position creation time"
        datetime updated_at "Position last update time"
    }

    POSITION_MODIFICATIONS {
        string modification_id PK "Unique modification identifier"
        string position_id FK "Related position"
        string modification_type "BREAKEVEN, TRAILING, PARTIAL_CLOSE, MODIFY_SL, MODIFY_TP"
        float old_value "Previous value before modification"
        float new_value "New value after modification"
        string reason "Reason for modification"
        boolean success "Modification execution success status"
        string error_message "Error details if modification failed"
        datetime executed_at "Modification execution timestamp"
    }

    PARTIAL_CLOSES {
        string partial_close_id PK "Unique partial close identifier"
        string position_id FK "Related position"
        float close_price "Price at which partial close was executed"
        float volume_closed "Volume/lot size closed"
        float profit_pips "Profit in pips for closed portion"
        float profit_usd "Profit in USD for closed portion"
        float remaining_volume "Remaining position volume"
        datetime close_time "Partial close execution time"
        string reason "Reason for partial close"
    }

    %% Strategy Analysis Entities
    ZONES {
        string zone_id PK "Unique zone identifier"
        string session_id FK "Related trading session"
        string symbol "Trading symbol"
        string timeframe "M1, M5, M15, H1, H4, D1, W1"
        string trading_type "Trading type when zone was detected"
        string zone_type "SUPPLY or DEMAND"
        float price_level "Zone price level"
        float strength_score "Zone strength score (0-100)"
        float volume_confirmation "Volume confirmation multiplier"
        int test_count "Number of times zone has been tested"
        float freshness_score "Zone freshness score (0-1)"
        boolean is_valid "Zone validity status"
        datetime first_formed "When zone was first formed"
        datetime last_tested "When zone was last tested"
        datetime created_at "Zone record creation time"
        datetime updated_at "Zone record last update"
    }

    TRADING_SIGNALS {
        string signal_id PK "Unique signal identifier"
        string session_id FK "Related trading session"
        string zone_id FK "Related supply/demand zone"
        string symbol "Trading symbol"
        string timeframe "Signal timeframe"
        string trading_type "Trading type for signal"
        string direction "BUY or SELL"
        float entry_price "Suggested entry price"
        float stop_loss "Suggested stop loss level"
        float take_profit "Suggested take profit level"
        float foundation_score "Foundation strategy score"
        json enhancement_scores "Enhancement layers scores (6 layers)"
        float final_confidence "Weighted final confidence score"
        float risk_reward_ratio "Risk to reward ratio"
        string signal_status "GENERATED, EXECUTED, EXPIRED, CANCELLED"
        datetime generated_at "Signal generation timestamp"
        datetime expires_at "Signal expiration timestamp"
    }

    SIGNAL_EXECUTIONS {
        string execution_id PK "Unique execution identifier"
        string signal_id FK "Related trading signal"
        string position_id FK "Created position (if successful)"
        string execution_type "MANUAL, AUTOMATED"
        boolean success "Execution success status"
        string failure_reason "Reason for execution failure"
        float execution_price "Actual execution price"
        float slippage "Price slippage from expected"
        datetime execution_time "Signal execution timestamp"
    }

    %% Market Data Entities
    MARKET_DATA {
        string data_id PK "Unique market data identifier"
        string symbol "Trading symbol"
        string timeframe "Data timeframe"
        datetime timestamp "Data timestamp"
        float open_price "Opening price"
        float high_price "Highest price"
        float low_price "Lowest price"
        float close_price "Closing price"
        float volume "Trading volume"
        float spread "Bid-ask spread"
        json technical_indicators "RSI, MA, and other indicators"
        datetime created_at "Data record creation time"
    }

    SYMBOL_INFO {
        string symbol PK "Trading symbol"
        string asset_class "Asset classification"
        string description "Symbol description"
        float pip_size "Pip size for symbol"
        float pip_value_per_lot "USD value per pip for 1 lot"
        int digits "Decimal places for price"
        float min_volume "Minimum trading volume"
        float max_volume "Maximum trading volume"
        float volume_step "Volume increment step"
        boolean is_active "Symbol trading status"
        json market_hours "Trading hours information"
        datetime last_updated "Symbol info last update"
    }

    %% Risk Management Entities
    RISK_METRICS {
        string risk_id PK "Unique risk metric identifier"
        string session_id FK "Related trading session"
        string position_id FK "Related position (optional)"
        float account_balance "Current account balance"
        float total_exposure "Total market exposure"
        float used_margin "Currently used margin"
        float free_margin "Available free margin"
        float daily_pnl "Daily profit/loss"
        float max_drawdown "Maximum drawdown reached"
        float risk_percentage "Current account risk percentage"
        int active_positions "Number of active positions"
        json risk_limits "Risk limits configuration"
        datetime calculated_at "Risk calculation timestamp"
    }

    RISK_VIOLATIONS {
        string violation_id PK "Unique violation identifier"
        string risk_id FK "Related risk metric"
        string violation_type "EXPOSURE_LIMIT, DRAWDOWN_LIMIT, POSITION_LIMIT"
        string severity "LOW, MEDIUM, HIGH, CRITICAL"
        string description "Violation description"
        json violation_details "Detailed violation information"
        boolean resolved "Violation resolution status"
        datetime occurred_at "Violation occurrence time"
        datetime resolved_at "Violation resolution time"
    }

    %% System Health & Monitoring
    SYSTEM_HEALTH {
        string health_id PK "Unique health record identifier"
        string session_id FK "Related trading session"
        int active_positions "Current active positions count"
        boolean mt5_connection_status "MT5 connection status"
        boolean database_status "Database connection status"
        float cpu_usage "System CPU usage percentage"
        float memory_usage "System memory usage percentage"
        json component_status "Individual component status"
        datetime last_data_update "Last market data update"
        datetime recorded_at "Health record timestamp"
    }

    AUDIT_LOG {
        string log_id PK "Unique audit log identifier"
        string session_id FK "Related trading session"
        string entity_type "Type of entity modified"
        string entity_id "ID of modified entity"
        string action_type "CREATE, UPDATE, DELETE, EXECUTE"
        json old_values "Values before modification"
        json new_values "Values after modification"
        string user_agent "System component that made change"
        string ip_address "IP address (if applicable)"
        datetime action_time "Action execution timestamp"
    }

    %% Configuration & Settings
    BOT_CONFIGURATIONS {
        string config_id PK "Unique configuration identifier"
        string profile_name "Configuration profile name"
        string trading_type "Default trading type"
        json strategy_settings "Strategy configuration"
        json risk_settings "Risk management settings"
        json position_settings "Position management settings"
        json notification_settings "Notification configuration"
        boolean is_active "Configuration active status"
        datetime created_at "Configuration creation time"
        datetime updated_at "Configuration last update"
    }

    %% =============================================================================
    %% RELATIONSHIPS
    %% =============================================================================

    %% Core relationships
    TRADING_SESSIONS ||--o{ POSITIONS : "manages"
    TRADING_SESSIONS ||--o{ ZONES : "analyzes"
    TRADING_SESSIONS ||--o{ TRADING_SIGNALS : "generates"
    TRADING_SESSIONS ||--o{ SYSTEM_HEALTH : "monitors"
    TRADING_SESSIONS ||--o{ RISK_METRICS : "tracks"
    TRADING_SESSIONS ||--o{ AUDIT_LOG : "logs"

    %% Position management relationships
    POSITIONS ||--o{ POSITION_MODIFICATIONS : "has_modifications"
    POSITIONS ||--o{ PARTIAL_CLOSES : "executes_partial_closes"
    POSITIONS ||--o{ RISK_METRICS : "risk_tracked_for"

    %% Strategy relationships
    ZONES ||--o{ TRADING_SIGNALS : "generates_signals"
    TRADING_SIGNALS ||--o{ SIGNAL_EXECUTIONS : "executed_as"
    SIGNAL_EXECUTIONS ||--o{ POSITIONS : "creates_positions"

    %% Market data relationships
    SYMBOL_INFO ||--o{ POSITIONS : "defines_trading_params"
    SYMBOL_INFO ||--o{ MARKET_DATA : "provides_data_for"
    SYMBOL_INFO ||--o{ ZONES : "analyzed_for"

    %% Risk management relationships
    RISK_METRICS ||--o{ RISK_VIOLATIONS : "detects_violations"

    %% Configuration relationships
    BOT_CONFIGURATIONS ||--o{ TRADING_SESSIONS : "configures_sessions"